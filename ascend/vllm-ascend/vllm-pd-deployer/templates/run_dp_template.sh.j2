#!/bin/bash
# Auto-generated by vllm-pd-deployer
# Node: {{ node.name }}
# Role: {{ role }}

export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:/usr/local/lib

# Network configuration
nic_name="{{ node.nic_name }}"
local_ip={{ node.host }}

# Environment variables from global config
{% for key, value in global_env.items() %}
export {{ key }}={{ value }}
{% endfor %}

# Node-specific environment overrides
{% for key, value in node.env_override.items() %}
export {{ key }}={{ value }}
{% endfor %}

# Network interface settings
export HCCL_IF_IP=$local_ip
export GLOO_SOCKET_IFNAME=$nic_name
export TP_SOCKET_IFNAME=$nic_name
export HCCL_SOCKET_IFNAME=$nic_name

# GPU device visibility
export ASCEND_RT_VISIBLE_DEVICES=$1

{% if role == 'prefill' %}
# Prefill-specific environment
export VLLM_TORCH_PROFILER_DIR=./profile_{{ node.dp_rank_start }}
export VLLM_TORCH_PROFILER_WITH_STACK=1
{% endif %}

{% if role == 'decode' %}
# Decode-specific environment  
export TASK_QUEUE_ENABLE=1
{% endif %}

# vLLM serve command
vllm serve {{ model.path }} \
    --host 0.0.0.0 \
    --port $2 \
    --data-parallel-size $3 \
    --data-parallel-rank $4 \
    --data-parallel-address $5 \
    --data-parallel-rpc-port $6 \
    --tensor-parallel-size $7 \
    --enable-expert-parallel \
    --seed {{ vllm_config.seed }} \
    --served-model-name {{ model.name }} \
    --max-model-len {{ model.max_model_len }} \
    --max-num-batched-tokens {{ vllm_config.max_num_batched_tokens }} \
    --trust-remote-code \
    --max-num-seqs {{ vllm_config.max_num_seqs }} \
    {% if role == 'prefill' and speculative.enabled %}
    --speculative-config '{"num_speculative_tokens": {{ speculative.num_speculative_tokens }}, "method":"{{ speculative.method }}"}' \
    {% endif %}
    --gpu-memory-utilization {{ vllm_config.gpu_memory_utilization }} \
    --enforce-eager \
    --quantization {{ model.quantization }} \
    {% if role == 'prefill' %}
    --profiler-config '{"profiler": "torch", "torch_profiler_dir": "./vllm_profile", "torch_profiler_with_stack": "true"}' \
    {% endif %}
    --additional-config '{{ additional_config | tojson }}' \
    --kv-transfer-config '{{ kv_transfer_config | tojson }}' 2>&1 | tee glm.log
